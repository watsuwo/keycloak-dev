# コピーして使う: cp .env.example .env
# .env はgit管理外 (.gitignore済み)

# ===== Keycloak =====
# 再現性のために具体的なパッチバージョンに固定するのを推奨 (例: 26.0.7)
KEYCLOAK_VERSION=26.0

# 初期管理者 (本番環境では必ず変更)
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# 管理(健康/メトリクス)ポート — localhost直接公開
KC_MGMT_PORT=9000

# ログレベル: INFO / DEBUG / TRACE / WARN
KC_LOG_LEVEL=INFO

# Keycloakの外部公開URL (ブラウザ・クライアントから見えるURL)
# HTTPS_PORT を 443以外にする場合はここも合わせて変更すること
# 例: HTTPS_PORT=8443 にしたなら KC_HOSTNAME=https://keycloak.localtest.me:8443
KC_HOSTNAME=https://keycloak.localtest.me

# ===== Traefik (リバースプロキシ / TLS終端) =====
TRAEFIK_VERSION=v3.1

# サービスホスト名のベースドメイン
# 既定の *.localtest.me は自動で 127.0.0.1 に解決されるため /etc/hosts 編集不要
# 独自ドメイン (例: dev.example.local) を使う場合は /etc/hosts に
#   "127.0.0.1 keycloak.dev.example.local mailhog.dev.example.local"
# を追加 + make certs-regen で証明書再生成が必要
BASE_DOMAIN=localtest.me

# 公開ポート (Traefik)
HTTP_PORT=80
HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8081

# ===== PostgreSQL =====
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak

# ===== Mailhog (開発用SMTP) =====
# SMTP受信ポートのみホスト直接公開 (Web UIはTraefik経由)
MAILHOG_SMTP_PORT=1025

# ===== WireMock (モックAPIサーバ) =====
# スタブ定義: mock-api/mappings/*.json
# 静的レスポンスファイル: mock-api/__files/
# 管理API (スタブ追加・リセット等): http://localhost:${MOCK_API_PORT}/__admin/
# Traefik経由URL: https://mock-api.${BASE_DOMAIN}/
WIREMOCK_VERSION=3.13.0
MOCK_API_PORT=8082
