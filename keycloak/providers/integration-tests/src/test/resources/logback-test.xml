<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Testcontainers系のログを抑制 (詳しく見たければ DEBUG に上げる) -->
    <logger name="org.testcontainers" level="INFO"/>
    <logger name="com.github.dockerjava" level="WARN"/>
    <logger name="dasniko.testcontainers.keycloak" level="INFO"/>

    <!-- Keycloak Admin Client のクライアントログを抑制 -->
    <logger name="org.keycloak" level="WARN"/>
    <logger name="org.jboss.resteasy" level="WARN"/>
</configuration>
