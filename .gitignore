e2e-tests/node_modules/
e2e-tests/test-results/
e2e-tests/playwright-report/
e2e-tests/playwright/.cache/
e2e-tests/dist/

# Claude Code 個人設定
.claude/settings.local.json
.claude/projects/

# ビルド成果物 (Maven/Gradle)
target/
build/
*.class
*.jar
!**/lib/*.jar

